# Copy to .env and fill in. NEVER commit .env with real values.

# --- LLM-agnostic model gateway ---------------------------------------------
# Pick any provider per role. Format: "provider:model".
# Providers: anthropic | openai | google_genai | bedrock | azure_openai | mistralai | ollama
CODESHIFT_PROFILE_REASONING=anthropic:claude-opus-4-8
CODESHIFT_PROFILE_CODEGEN=anthropic:claude-sonnet-4-6
CODESHIFT_PROFILE_CHEAP=anthropic:claude-haiku-4-5-20251001
CODESHIFT_PROFILE_EMBED=openai:text-embedding-3-small

# Optional fallback profile used when the primary provider errors/rate-limits.
CODESHIFT_FALLBACK_REASONING=openai:gpt-4.1
CODESHIFT_FALLBACK_CODEGEN=openai:gpt-4.1-mini

# Provider API keys — set only the ones you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
# For local models via Ollama, no key needed; set OLLAMA_BASE_URL if remote.
# OLLAMA_BASE_URL=http://localhost:11434

# --- State / persistence -----------------------------------------------------
# Leave DATABASE_URL empty to run the graph with an in-memory checkpointer
# (great for the first run). Set it to enable durable, resumable runs.
DATABASE_URL=postgresql://codeshift:codeshift@localhost:5432/codeshift

# --- Observability (LangSmith) ----------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=codeshift-dev

# --- Cost governance ---------------------------------------------------------
# Default per-project budget in USD; the gateway refuses/downgrades near the cap.
CODESHIFT_DEFAULT_BUDGET_USD=25
