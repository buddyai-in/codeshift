# Copy values into your shell / run config. NEVER commit real secrets.
# The Spring Boot apps read these environment variables (see application.yml).

# --- Persistence (Postgres + pgvector) --------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/codeshift
DB_USER=codeshift
DB_PASSWORD=codeshift

# --- LLM providers (LLM-agnostic gateway) -----------------------------------
# Set only the provider(s) you use. Which model each capability profile uses is
# configured in codeshift-api/src/main/resources/application.yml
# (codeshift.model.profiles.*) — swap providers/models there with no code change.
# To actually call a model, also add the matching Spring AI starter to
# codeshift-api/pom.xml, e.g. spring-ai-starter-model-anthropic.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=

# --- Observability (optional) -----------------------------------------------
# LangChain/LangSmith-style tracing is added in Phase 1 via Micrometer/OTel.
